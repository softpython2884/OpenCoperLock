// OpenCoperLock data model.
// See docs/ARCHITECTURE.md for the rationale behind the encryption-related fields.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum EncMode {
  SERVER // server-side envelope encryption at rest (scannable)
  ZK // zero-knowledge: encrypted client-side, server is blind
}

enum AvStatus {
  PENDING
  CLEAN
  INFECTED
  SKIPPED // scanning disabled or scanner unreachable
}

enum JobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

enum ShareViewType {
  RAW
  PAGE
}

enum ShareAccess {
  PUBLIC
  CODE
  AUTHENTICATED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  // null = unlimited personal quota
  quotaBytes   BigInt?
  // denormalised running total of bytes the user stores, kept in sync on upload/delete
  usedBytes    BigInt   @default(0)
  disabled     Boolean  @default(false)
  // Two-factor (TOTP). `totpSecret` is also used as the pending secret during setup.
  totpSecret   String?
  totpEnabled  Boolean  @default(false)
  // Last successful login, used by the optional inactivity auto-wipe.
  lastLoginAt  DateTime?
  // If set, a daily job permanently deletes the user's files after this many days without a login.
  autoDeleteAfterDays Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions        Session[]
  folders         Folder[]
  files           FileObject[]
  quickCodes      QuickUploadCode[]
  remoteJobs      RemoteUploadJob[]
  auditLogs       AuditLog[]
  shares          ShareLink[]
  recoveryCodes   RecoveryCode[]
  apiTokens       ApiToken[]
  webhooks        Webhook[]

  @@index([email])
}

// One-time 2FA recovery codes, stored as SHA-256 hashes.
model RecoveryCode {
  id       String    @id @default(cuid())
  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash String
  usedAt   DateTime?

  @@index([userId])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // per-session secret used to derive the double-submit CSRF token
  csrfSecret String
  // captured at login so the user can review where they are signed in
  ip         String?
  userAgent  String?
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Folder {
  id              String   @id @default(cuid())
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  parentId        String?
  parent          Folder?  @relation("FolderChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children        Folder[] @relation("FolderChildren")
  name            String
  isZeroKnowledge Boolean  @default(false)
  // Per-vault random salt for the client's PBKDF2 key derivation (ZK folders only).
  // Not secret; storing it per vault defeats cross-vault precomputation. null = legacy.
  zkSalt          String?
  // Opaque "key check value": a constant encrypted client-side with the vault key when the
  // vault is created. The client decrypts it on unlock to confirm the passphrase is correct
  // (so a typo is caught immediately instead of corrupting uploads). null = legacy vault.
  zkVerifier      String?
  // Soft-delete: when set, the folder is in the Trash (hidden from the Drive) until it is
  // restored or purged. Trashing a folder cascades this timestamp to its whole subtree.
  deletedAt       DateTime?
  createdAt       DateTime @default(now())

  files  FileObject[]
  shares ShareLink[]

  @@unique([ownerId, parentId, name])
  @@index([ownerId])
  @@index([deletedAt])
}

model FileObject {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  folderId  String?
  folder    Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  name      String
  sizeBytes BigInt
  mimeType  String   @default("application/octet-stream")
  // Opaque key into the storage driver (e.g. a path under STORAGE_PATH).
  storageKey String  @unique
  encMode   EncMode  @default(SERVER)

  // ── SERVER mode crypto material ──
  // base64 DEK wrapped by the deployment MASTER_KEY; null for ZK files.
  wrappedKey String?
  // base64 IV used to encrypt the file content; null for ZK files (the IV lives in the blob).
  iv         String?
  // base64 GCM auth tag for the file content; null for ZK files.
  authTag    String?

  // ── ZK mode crypto material (opaque to the server) ──
  // client-encrypted original filename (base64); the `name` column holds a placeholder.
  zkEncryptedName String?
  // base64 wrapped data key (wrapped by the user's passphrase-derived key).
  zkWrappedKey    String?
  // base64 IV chosen by the client.
  zkIv            String?

  sha256   String?
  avStatus AvStatus @default(PENDING)
  // Soft-delete: when set, the file is in the Trash (hidden from listings) until restored
  // or purged. Trashed files still count against quota until they are permanently removed.
  deletedAt DateTime?
  createdAt DateTime @default(now())

  shares   ShareLink[]
  versions FileVersion[]

  @@index([ownerId])
  @@index([folderId])
  @@index([deletedAt])
}

// A prior revision of a SERVER-mode file (kept for text-like files). Holds its own
// ciphertext blob and crypto material, so restoring is just a metadata swap.
model FileVersion {
  id         String     @id @default(cuid())
  fileId     String
  file       FileObject @relation(fields: [fileId], references: [id], onDelete: Cascade)
  storageKey String     @unique
  sizeBytes  BigInt
  mimeType   String
  wrappedKey String
  iv         String
  authTag    String
  sha256     String?
  createdAt  DateTime   @default(now())

  @@index([fileId])
}

model QuickUploadCode {
  id             String    @id @default(cuid())
  code           String    @unique
  createdById    String
  createdBy      User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  // Files land here. null = the creator's root.
  targetFolderId String?
  // per-upload size cap in bytes; null = only bounded by quota
  maxBytes       BigInt?
  expiresAt      DateTime?
  // null = unlimited redemptions
  usageLimit     Int?
  usageCount     Int       @default(0)
  // optional argon2 hash guarding the drop zone
  passwordHash   String?
  createdAt      DateTime  @default(now())

  @@index([code])
  @@index([createdById])
}

model RemoteUploadJob {
  id        String    @id @default(cuid())
  ownerId   String
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sourceUrl String
  folderId  String?
  status    JobStatus @default(QUEUED)
  sizeBytes BigInt?
  error     String?
  fileId    String?
  // simple lease so a single worker loop processes each job once
  startedAt DateTime?
  // retry bookkeeping: how many times we've tried, and when the next try is allowed
  attempts  Int       @default(0)
  nextRunAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
  @@index([ownerId])
  @@index([status, nextRunAt])
}

// Generic failure counter for brute-force protection. One row per (bucket, key):
//   - bucket "login" keyed by email           -> account lockout with backoff
//   - bucket "quick" keyed by "<code>:<ip>"   -> Quick-Upload password guessing ban
// Rows are pruned by the maintenance loop once they expire.
model Throttle {
  id          String    @id @default(cuid())
  bucket      String
  key         String
  failures    Int       @default(0)
  firstFailAt DateTime  @default(now())
  lockedUntil DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([bucket, key])
  @@index([lockedUntil])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  target    String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
}

model Setting {
  // single-row table (id = "global")
  id                   String   @id @default("global")
  globalStorageCapBytes BigInt  @default(0)
  // Optional VirusTotal API key set from the admin panel; overrides VIRUSTOTAL_API_KEY in .env.
  virustotalApiKey     String?
  updatedAt            DateTime @updatedAt
}

// A personal access token for the public REST API (Authorization: Bearer ocl_…). Only a SHA-256
// hash of the secret is stored; the plaintext is shown once at creation. `scopes` is a CSV of
// "read"/"write"; `folderId` optionally restricts the token to one folder (and its subtree).
model ApiToken {
  id         String    @id @default(cuid())
  ownerId    String
  owner      User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name       String
  tokenHash  String    @unique
  prefix     String
  scopes     String
  folderId   String?
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([ownerId])
}

// An outgoing webhook: POSTed when a file lands in the owner's storage (optionally limited to
// one folder). `secret` (if set) signs the body with HMAC-SHA256. lastStatus/lastError record
// the most recent delivery for the UI.
model Webhook {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  url        String
  secret     String?
  folderId   String?
  active     Boolean  @default(true)
  lastStatus Int?
  lastError  String?
  createdAt  DateTime @default(now())

  @@index([ownerId])
}

// A shareable link to a SERVER-mode file or folder. ZK targets can't be shared (the
// server can't decrypt them). The opaque `token` is the URL slug.
model ShareLink {
  id        String        @id @default(cuid())
  token     String        @unique
  ownerId   String
  owner     User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  fileId    String?
  file      FileObject?   @relation(fields: [fileId], references: [id], onDelete: Cascade)
  folderId  String?
  folder    Folder?       @relation(fields: [folderId], references: [id], onDelete: Cascade)
  viewType  ShareViewType @default(PAGE)
  access    ShareAccess   @default(PUBLIC)
  // argon2 hash of the code, when access = CODE
  codeHash      String?
  allowDownload Boolean   @default(true)
  expiresAt     DateTime?
  maxDownloads  Int?
  downloadCount Int       @default(0)
  createdAt     DateTime  @default(now())

  @@index([ownerId])
  @@index([token])
}
